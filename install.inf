#!/bin/infernal

# Script de instalacion de Casata desde ZIP en Infernal
# GPL v3, Aros Legendarios, David Baña Szymaniak
# Basado en el install.sh

Full = false
NoInstalar = false
YaMostrasteHelp = false
UseCustomPath = false

function MostrarHelp()
    if YaMostrasteHelp == false then
        success("Casata Installer Help")
        echo "---------------------"
        echo ""
        warn("Tienes que ejecutar este script como root (sudo)")
        echo "Los flags son:"
        echo "  --help (-h): muestra esta ayuda."
        echo "  --version (-v): muestra la versión que tienes en el paquete localmente."
        echo "  --full (-f): Te instala la última versión de Casata, descargándola de internet."
        echo "  --license (-l): muestra la licencia, proyecto y autor del código."
        echo "  --gpl (--gplv3): muestra el texto completo de la licencia GPL v3."
        echo ""
        echo "Por cierto: ejecuta `./install.sh --flag` con la terminal abierta en la carpeta de este script."
        YaMostrasteHelp = true
    fi
fi

flags (0, # aqui se definen los flags
    --help|-h{
        MostrarHelp()
        NoInstalar = true
    }

    --version|-v{
        echo "La versión que vas a instalar (la que tienes aquí localmente) es la:"
        cat usr/local/casata/VERSION
        NoInstalar = true
    }

    #flags de uso
    --full|-f{
        echo "FLAG: Instalando versión completa con internet. Local como fallback."
        Full = true
    }
    --path=string path{
         CustomPath = $path
         UseCustomPath = true
    }

    #flags de licencia
    --license|-l{
        echo "Licencia GPL v3, Lynds Corp., Aros Legendarios, David Baña Szymaniak."
        NoInstalar = true
    }
    --gpl|--gplv3{
        cat usr/local/casata/LICENSE
        NoInstalar = true
    }
    *{
    }
)

user = whoami
if user != "root" then
    MostrarHelp()
    exit(1)
fi

if UseCustomPath == true then
    NoInstalar = true

    mkdir -p $CustomPath

    echo "Dándole permisos de ejecución a usr/bin/casata para que reconozca el comando y a los módulos..."
    chmod +x usr/bin/casata
    chmod +x ./usr/local/casata/modules/*

    echo "Copiando el router (casata.sh) al usr/bin/casata del Path personalizado para que sea un comando en la terminal..."
    mkdir -p "$CustomPath/usr/bin"
    cp usr/bin/casata "$CustomPath/usr/bin/casata"

    #copiar el root de Casata
    echo "Copiando root de Casata en /usr/local/casata/ del path elegido..."
    mkdir -p "$CustomPath/usr/local"
    cp -r usr/local/casata/ "$CustomPath/usr/local/"
    
    echo ""
    success("----------------------------------------------------------------------------------")
    success("¡Casata instalado correctamente!")
    warn("Versión:")
    cat "$CustomPath/usr/local/casata/VERSION"

    echo ""
    print("Te recomiendo ejecutar `sudo casata add oficial forge community others` para añadir los repositorios principales.")
    print("¡Prueba a escribir `casata` en tu terminal!")

    exit(0)
fi

if NoInstalar == false then
    #copiar el script para que sea un comando
    echo "Copiando el router (casata.sh) al /usr/bin/casata para que sea un comando en la terminal..."
    cp usr/bin/casata /usr/bin/casata

    echo "Dándole permisos de ejecución a /usr/bin/casata para que reconozca el comando..."
    chmod +x ./usr/bin/casata

    #copiar el root de Casata
    echo "Copiando root de Casata en /usr/local/casata/..."
    cp -r usr/local/casata/ /usr/local/

    echo "Dando permisos de ejecución a los módulos de Casata por si acaso..."
    chmod +x /usr/local/casata/modules/*

    if Full == true then
        echo "Actualizando Casata si se puede..."
        casata install casata -y && casata add oficial forge community others || echo "No se pudo actualizar. Revisa tu conexión a internet o firewall a github.com."
    fi

    echo ""
    echo "----------------------------------------------------------------------------------"
    echo "¡Casata instalado correctamente!"
    echo "Versión:"
    cat /usr/local/casata/VERSION

    if Full == false then
        echo ""
        print("Te recomiendo ejecutar `sudo casata add oficial forge community others` para añadir los repositorios principales.")
        print("¡Prueba a escribir `casata` en tu terminal!")
    fi

    exit(0) #todo salio bien :)
fi
